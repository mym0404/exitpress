{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["packages/web/src/*"],
      "@exitpress/blog-naver/*": ["packages/blog-naver/src/*"],
      "@exitpress/blog-tistory/*": ["packages/blog-tistory/src/*"],
      "@exitpress/domain/*": ["packages/domain/src/*"],
      "@exitpress/engine/*": ["packages/engine/src/*"],
      "@exitpress/server/*": ["packages/server/src/*"],
      "@exitpress/web/*": ["packages/web/src/*"],
      "@tests/*": ["tests/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "packages/**/*.d.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "packages/web/vite.config.ts",
    "packages/web/vite.pages.config.ts"
  ]
}
