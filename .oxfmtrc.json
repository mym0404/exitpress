{
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": false,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "sortImports": {
    "groups": [
      "value-builtin",
      "value-external",
      "value-internal",
      "type-builtin",
      "type-external",
      "type-internal",
      "type-parent",
      "type-sibling",
      "type-index",
      "value-parent",
      "value-sibling",
      "value-index",
      "unknown"
    ]
  },
  "ignorePatterns": [".eye/**"]
}
