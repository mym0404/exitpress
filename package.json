{
  "name": "exitpress",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development bun --watch packages/server/src/Server.ts",
    "start": "pnpm build:ui && bun packages/server/src/Server.ts",
    "build:ui": "pnpm --filter @exitpress/web build",
    "build:server": "tsc -p tsconfig.json",
    "build": "pnpm build:ui && pnpm build:server",
    "format": "oxfmt \"*.json\" \"*.jsonc\" \"*.ts\" \"*.tsx\" \"packages/**/*.{ts,tsx,css,json,jsonc}\" \"scripts/**/*.ts\" \"tests/**/*.{ts,tsx}\" \".agents/skills/**/*.ts\"",
    "check:fmt": "oxfmt --check \"*.json\" \"*.jsonc\" \"*.ts\" \"*.tsx\" \"packages/**/*.{ts,tsx,css,json,jsonc}\" \"scripts/**/*.ts\" \"tests/**/*.{ts,tsx}\" \".agents/skills/**/*.ts\"",
    "check:lint": "oxlint --no-error-on-unmatched-pattern \"*.ts\" \"*.tsx\" packages scripts tests .agents/skills",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "storybook:generate": "bun scripts/storybook/generate-catalog.ts",
    "storybook:check": "bun scripts/storybook/generate-catalog.ts --check",
    "check:unused": "bun scripts/maintenance/check-unused.ts",
    "gh:update-branches": "bun scripts/maintenance/update-open-pr-branches.ts",
    "test": "vitest run --configLoader runner --silent",
    "test:coverage": "vitest run --configLoader runner --silent --coverage",
    "test:offline": "vitest run --configLoader runner --silent",
    "test:provider:mock": "bun tests/e2e/run-provider-mock-export.ts",
    "test:provider:tistory": "bun tests/e2e/run-provider-tistory-live.ts",
    "test:network": "pnpm build:ui && bun tests/e2e/run-ui-live-resume-export.ts && bun tests/e2e/run-ui-live-resume-export.ts --case se2-table && bun tests/e2e/run-ui-live-upload.ts",
    "test:network:resume-export": "bun tests/e2e/run-ui-live-resume-export.ts",
    "test:network:resume-export:se2-table": "bun tests/e2e/run-ui-live-resume-export.ts --case se2-table",
    "test:network:upload": "pnpm build:ui && bun tests/e2e/run-ui-live-upload.ts",
    "smoke:ui": "pnpm build:ui && bun tests/e2e/run-ui-smoke-suite.ts",
    "check:local": "pnpm check:fmt && pnpm check:lint && pnpm typecheck && pnpm storybook:check && pnpm test:offline",
    "check:full": "pnpm check:local && pnpm smoke:ui"
  },
  "devDependencies": {
    "@exitpress/domain": "workspace:*",
    "@exitpress/engine": "workspace:*",
    "@exitpress/server": "workspace:*",
    "@exitpress/web": "workspace:*",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "cheerio": "catalog:",
    "jsdom": "catalog:",
    "knip": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "yaml": "catalog:"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
